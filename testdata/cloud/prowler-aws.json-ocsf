  "finding_info": {
   "created_time": 1783301528,
   "created_time_dt": "2026-07-05T21:32:08.523936",
   "desc": "**ACM certificates** are assessed for **time to expiration** against a configurable threshold. Certificates close to end of validity or already expired are surfaced, covering those attached to services and, *if in scope*, unused ones.",
   "title": "ACM certificate expires in more than the configured threshold of days",
   "types": [
    "Software and Configuration Checks/AWS Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/AWS Foundational Security Best Practices",
    "Effects/Denial of Service"
   ],
   "uid": "prowler-aws-acm_certificates_expiration_check-123456789012-us-east-1-2dcce65e-29aa-4511-86c3-818afb4bc7b8"
  },
  "resources": [
   {
    "cloud_partition": "aws",
    "region": "us-east-1",
    "data": {
     "details": "",
     "metadata": {
      "arn": "arn:aws:acm:us-east-1:123456789012:certificate/2dcce65e-29aa-4511-86c3-818afb4bc7b8",
      "name": "acme.example",
      "id": "2dcce65e-29aa-4511-86c3-818afb4bc7b8",
      "type": "AMAZON_ISSUED",
      "key_algorithm": "RSA-2048",
      "tags": [
       {
        "Key": "managed-by",
