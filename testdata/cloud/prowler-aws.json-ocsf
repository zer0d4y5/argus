  "finding_info": {
   "created_time": 1783301528,
   "created_time_dt": "2026-07-05T21:32:08.523936",
   "desc": "**AWS CloudTrail trails** are evaluated for **log file integrity validation** being enabled (`LogFileValidationEnabled`).\n\nWhen enabled, CloudTrail generates signed digest files to verify that S3-delivered log files remain unchanged.",
   "title": "CloudTrail trail has log file validation enabled",
   "types": [
    "Software and Configuration Checks/AWS Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/AWS Foundational Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/CIS AWS Foundations Benchmark"
   ],
   "uid": "prowler-aws-cloudtrail_log_file_validation_enabled-123456789012-us-east-1-acme-trail"
  },
  "resources": [
   {
    "cloud_partition": "aws",
    "region": "us-east-1",
    "data": {
     "details": "",
     "metadata": {
      "name": "acme-trail",
      "is_multiregion": true,
      "home_region": "us-east-1",
      "arn": "arn:aws:cloudtrail:us-east-1:123456789012:trail/acme-trail",
      "region": "us-east-1",
      "is_logging": true,
      "log_file_validation_enabled": false,
      "latest_cloudwatch_delivery_time": null,
      "s3_bucket": "acme-cloudtrail-123456789012",
      "kms_key": null,
      "log_group_arn": null,
      "data_events": [
       {
        "is_advanced": false,
        "event_selector": {
         "ReadWriteType": "All",
         "IncludeManagementEvents": true,
         "DataResources": [],
         "ExcludeManagementEventSources": []
        }
       }
      ],
      "tags": [],
