  "activity_name": "Create",
  "activity_id": 1,
  "finding_info": {
   "created_time": 1783301528,
   "created_time_dt": "2026-07-05T21:32:08.523936",
   "desc": "**AWS CloudTrail trails** are evaluated for use of **SSE-KMS** with a customer-managed KMS key to encrypt delivered log files at rest in S3. Trails without a configured KMS key are identified. *Applies to single-Region and multi-Region trails.*",
   "title": "CloudTrail trail logs are encrypted at rest with a KMS key",
   "types": [
    "Software and Configuration Checks/AWS Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/AWS Foundational Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/CIS AWS Foundations Benchmark"
   ],
   "uid": "prowler-aws-cloudtrail_kms_encryption_enabled-123456789012-us-east-1-acme-trail"
  },
  "resources": [
   {
    "cloud_partition": "aws",
    "region": "us-east-1",
    "data": {
     "details": "",
     "metadata": {
      "name": "acme-trail",
      "is_multiregion": true,
      "home_region": "us-east-1",
      "arn": "arn:aws:cloudtrail:us-east-1:123456789012:trail/acme-trail",
      "region": "us-east-1",
      "is_logging": true,
      "log_file_validation_enabled": false,
      "latest_cloudwatch_delivery_time": null,
      "s3_bucket": "acme-cloudtrail-123456789012",
      "kms_key": null,
      "log_group_arn": null,
      "data_events": [
       {
        "is_advanced": false,
        "event_selector": {
         "ReadWriteType": "All",
         "IncludeManagementEvents": true,
         "DataResources": [],
         "ExcludeManagementEventSources": []
        }
       }
      ],
      "tags": [],
      "has_insight_selectors": null
     }
    },
    "group": {
     "name": "cloudtrail"
    },
    "labels": [],
    "name": "acme-trail",
    "type": "AwsCloudTrailTrail",
    "uid": "arn:aws:cloudtrail:us-east-1:123456789012:trail/acme-trail"
   }
  ],
  "category_name": "Findings",
  "category_uid": 2,
  "class_name": "Detection Finding",
  "class_uid": 2004,
  "cloud": {
   "account": {
    "name": "",
    "type": "AWS Account",
    "type_id": 10,
    "uid": "123456789012",
    "labels": []
   },
   "org": {
    "name": "",
    "ou_uid": "",
    "ou_name": "",
    "uid": ""
   },
   "provider": "aws",
   "region": "us-east-1"
  },
  "remediation": {
   "desc": "Enable **SSE-KMS** on every trail using a **customer-managed KMS key**. Apply **least privilege** so only authorized roles can `Decrypt`, and enforce **separation of duties** between key admins and log readers. Rotate keys and monitor key usage to provide **defense in depth** for CloudTrail data.",
   "references": [
    "https://hub.prowler.com/check/cloudtrail_kms_encryption_enabled"
   ]
  },
  "risk_details": "Absent a **customer-managed KMS key**, log protection relies only on storage permissions. Bucket misconfigurations or stolen credentials can expose audit data, aiding evasion and lateral movement. Missing key-level controls, rotation, and usage audit weaken **confidentiality** and **forensic integrity**.",
  "time": 1783301528,
  "time_dt": "2026-07-05T21:32:08.523936",
  "type_uid": 200401,
  "type_name": "Detection Finding: Create"
 },
