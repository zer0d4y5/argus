  "finding_info": {
   "created_time": 1783301528,
   "created_time_dt": "2026-07-05T21:32:08.523936",
   "desc": "**EBS volumes** are assessed for **encryption at rest** using **AWS KMS**.\n\nThe finding identifies volumes whose `encrypted` state is disabled, meaning data is stored unencrypted on block storage.",
   "title": "EBS volume is encrypted",
   "types": [
    "Software and Configuration Checks/AWS Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/AWS Foundational Security Best Practices",
    "Software and Configuration Checks/Industry and Regulatory Standards/CIS AWS Foundations Benchmark",
    "Effects/Data Exposure"
   ],
   "uid": "prowler-aws-ec2_ebs_volume_encryption-123456789012-us-east-1-vol-07db68811a679634b"
  },
  "resources": [
   {
    "cloud_partition": "aws",
    "region": "us-east-1",
    "data": {
     "details": "",
     "metadata": {
      "id": "vol-07db68811a679634b",
      "arn": "arn:aws:ec2:us-east-1:123456789012:volume/vol-07db68811a679634b",
      "region": "us-east-1",
      "encrypted": false,
      "tags": null
     }
    },
    "group": {
     "name": "ec2"
    },
    "labels": [],
    "name": "vol-07db68811a679634b",
    "type": "AwsEc2Volume",
    "uid": "arn:aws:ec2:us-east-1:123456789012:volume/vol-07db68811a679634b"
   }
  ],
  "category_name": "Findings",
  "category_uid": 2,
  "class_name": "Detection Finding",
  "class_uid": 2004,
  "cloud": {
   "account": {
    "name": "",
    "type": "AWS Account",
    "type_id": 10,
    "uid": "123456789012",
    "labels": []
   },
   "org": {
    "name": "",
    "ou_uid": "",
    "ou_name": "",
    "uid": ""
   },
   "provider": "aws",
   "region": "us-east-1"
  },
  "remediation": {
   "desc": "Encrypt all EBS volumes and enable `encryption by default` for new volumes and snapshot copies.\n\nApply **least privilege** to KMS keys, restrict snapshot sharing, and enforce **defense in depth** with policies and templates that prevent creation of unencrypted storage.",
   "references": [
    "https://hub.prowler.com/check/ec2_ebs_volume_encryption"
   ]
  },
  "risk_details": "Unencrypted volumes or snapshots can be copied, shared, or recovered and reveal raw data, undermining **confidentiality**.\n\nAdversaries with host or account access can read disks offline, harvest secrets, or alter system images, affecting **integrity** and enabling **lateral movement**.",
  "time": 1783301528,
  "time_dt": "2026-07-05T21:32:08.523936",
  "type_uid": 200401,
  "type_name": "Detection Finding: Create"
 },
